compra = float(input("Ingresa el monto de la compra: "))
if compra >= 1000:
    descuento = compra * 0.15
elif compra >= 500:
    descuento = compra * 0.10
else:
    descuento = 0

total = compra - descuento
print(f"Descuento aplicado: ${descuento:.2f}")
print(f"Total a pagar: ${total:.2f}")
